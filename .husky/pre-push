#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# LOCAL_SHA가 0000000000000000000000000000000000000000 이면 브랜치 삭제를 의미하므로 스킵
while read local_ref local_sha remote_ref remote_sha
do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  export REMOTE_SHA=$remote_sha
  export LOCAL_SHA=$local_sha

  echo "[Husky] HISTORY.md 업데이트 여부를 확인합니다..."
  node scripts/generate-history.js

  if ! git diff --quiet docs/HISTORY.md; then
    echo "[Husky] HISTORY.md 파일이 변경되었습니다. 커밋을 생성합니다."
    git add docs/HISTORY.md
    git commit -m "docs: auto-update history by Gemini [skip ci]"

    echo "[Husky] 새로운 커밋을 원격 저장소로 자동 푸시합니다..."
    # --no-verify를 사용하여 pre-push 훅이 무한 루프에 빠지지 않도록 방지하며 백그라운드 푸시
    git push origin main --no-verify

    echo "==============================================================="
    echo "✅ HISTORY.md 갱신 및 모든 커밋 푸시가 완료되었습니다!"
    echo "==============================================================="
    # 자동 푸시 후, 현재 진행 중이던 push는 취소(abort)하여 충돌 방지
    # (이미 위에서 최신 상태로 push 했으므로 현재의 push 프로세스는 중단하는 것이 올바름)
    exit 1
  fi
done
